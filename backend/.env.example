# 本地开发环境配置示例（复制为 .env 后修改）
# 生产环境必须通过环境变量注入真实值，禁止使用本文件中的占位符

APP_NAME=Factory R&D PMS
DEBUG=True
API_V1_PREFIX=/api/v1

# 数据库 - 本地开发默认使用 SQLite（无需安装 MySQL）
# 生产环境使用 MySQL：mysql+pymysql://user:pass@host:port/dbname?charset=utf8mb4
DATABASE_URL=sqlite:///./factory_pms.db
# 自动建表：开发环境 true，生产环境建议 false（使用 alembic upgrade head）
DB_AUTO_CREATE=true

# Redis - 可选，留空则不使用
REDIS_URL=

# JWT - SECRET_KEY 必须设置：留空时开发环境自动生成随机密钥（每次重启变化）
# 生产环境必须通过环境变量注入固定的随机密钥（至少 32 字符）
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MinIO - 可选，留空使用本地文件存储
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=factory-pms
MINIO_SECURE=False

# CORS - 生产环境必须指定具体域名列表，禁止使用 ["*"]
# 开发环境可设为 ["http://localhost:5173"]
CORS_ORIGINS=["http://localhost:5173"]
