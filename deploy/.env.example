# Docker 部署环境配置示例
# 复制为 .env 后修改所有密码与密钥为真实随机值

APP_NAME=Factory R&D PMS
DEBUG=False
API_V1_PREFIX=/api/v1

# 数据库 - MySQL 连接串（Docker 部署必须设置）
# 注意：MYSQL_PASSWORD 必须与下方 MYSQL_PASSWORD 一致
DATABASE_URL=mysql+pymysql://pms:pms_secret_change_me@mysql:3306/factory_pms?charset=utf8mb4

# MySQL 容器初始化参数（与 docker-compose.yml 配合使用）
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_DATABASE=factory_pms
MYSQL_USER=pms
MYSQL_PASSWORD=pms_secret_change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT - 生产环境必须设置为随机密钥（至少 32 字符）
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_change_me
MINIO_SECRET_KEY=minio_secret_change_me
MINIO_BUCKET=factory-pms
MINIO_SECURE=False

# CORS - 生产环境必须指定具体域名，禁止使用 ["*"]
CORS_ORIGINS=["http://localhost","http://localhost:80","http://frontend"]

# 前端 API 地址（前端打包时用）
VITE_API_BASE=/api/v1
